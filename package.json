{
  "name": "zentrade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:api & pnpm --dir zentrade-app dev",
    "dev:api": "cd zentrade-backend && AUTH_JWT_SECRET=${AUTH_JWT_SECRET:-zentrade-dev-secret-key-at-least-32-chars} ./venv/bin/python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:web": "pnpm --dir zentrade-app dev",
    "build": "pnpm --dir zentrade-app build"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
