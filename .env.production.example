# ── Domain ────────────────────────────────────────
# Your domain name (used for Nginx & SSL cert)
DOMAIN=trade.example.com

# ── Frontend ──────────────────────────────────────
# API URL as seen by the browser; leave as /api when using Nginx reverse proxy
NEXT_PUBLIC_API_URL=/api

# ── Auth (required) ───────────────────────────────
# Min 32 chars: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_DAYS=7
# Plain-HTTP only (not recommended): session cookie must not be Secure or browsers drop it.
# AUTH_COOKIE_INSECURE=1

# ── Backend CORS ──────────────────────────────────
# Comma-separated allowed origins, e.g. https://trade.example.com
CORS_ORIGINS=https://trade.example.com

# ── Market Data API Keys (optional) ──────────────
TWELVE_DATA_API_KEY=
COINGECKO_API_KEY=

# ── Certbot / Let's Encrypt ──────────────────────
CERTBOT_EMAIL=your-email@example.com
