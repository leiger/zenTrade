# Copy to .env.local (gitignored). Values must match your FastAPI backend where noted.

# Required for middleware: verify session cookie JWT. Must equal backend AUTH_JWT_SECRET (min 32 chars).
# Root `npm run dev` defaults backend to this value when AUTH_JWT_SECRET is unset.
AUTH_JWT_SECRET=zentrade-dev-secret-key-at-least-32-chars

# Optional. Session cookie max-age; keep in sync with backend AUTH_JWT_EXPIRES_DAYS if you change it.
# AUTH_JWT_EXPIRES_DAYS=7

# Server-side only: absolute origin for proxying /api/auth/* to FastAPI (avoids relative NEXT_PUBLIC_API_URL on server).
# API_URL=http://127.0.0.1:8000

# Browser API base (and server fallback in getBackendOrigin when absolute). Default in code uses localhost:8000.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
